generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameType {
  MTG
  PKM
  YGO
}

enum TournamentFormat {
  SWISS
  SINGLE_ELIM
}

enum TournamentState {
  OPEN
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum MatchResult {
  P1_WIN
  P2_WIN
  DRAW
  P1_WIN_GIVE
  P2_WIN_GIVE
  BYE
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  PLAYER
  ORGANIZER
  ADMIN
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  eloRating    Int       @default(1200)
  qrCode       String?   @unique
  role         UserRole  @default(PLAYER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tournaments      Participant[]
  matchesAsPlayer1  Match[]        @relation("Player1")
  matchesAsPlayer2  Match[]        @relation("Player2")
  organizedTournaments Tournament[] @relation("Organizer")

  @@map("users")
}

model Tournament {
  id           String           @id @default(uuid())
  name         String
  description  String?
  gameType     GameType         @map("game_type")
  format       TournamentFormat
  state        TournamentState  @default(OPEN)
  maxPlayers   Int              @map("max_players")
  rounds       Int              @default(0)
  currentRound Int              @default(0) @map("current_round")
  startTime    DateTime?        @map("start_time")
  endTime      DateTime?        @map("end_time")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  organizerId  String           @map("organizer_id")
  organizer   User             @relation("Organizer", fields: [organizerId], references: [id])

  participants Participant[]
  matches      Match[]

  @@map("tournaments")
}

model Participant {
  id               String  @id @default(uuid())
  userId           String  @map("user_id")
  tournamentId     String  @map("tournament_id")
  currentPoints    Int     @default(0) @map("current_points")
  omwPercentage    Float   @default(0.0) @map("omw_percentage")
  gwPercentage     Float   @default(0.0) @map("gw_percentage")
  seed             Int     @default(0)
  hasBye           Boolean @default(false) @map("has_bye")
  createdAt        DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  tournament  Tournament   @relation(fields: [tournamentId], references: [id])
  matchHistory Match[]     @relation("ParticipantMatches")

  @@unique([userId, tournamentId])
  @@map("participants")
}

model Match {
  id             String      @id @default(uuid())
  tournamentId   String     @map("tournament_id")
  roundNumber    Int        @map("round_number")
  tableNumber    Int?       @map("table_number")
  player1Id      String     @map("player1_id")
  player2Id      String?   @map("player2_id")
  result         MatchResult?
  status         MatchStatus @default(PENDING)
  player1Wins    Int        @default(0) @map("player1_wins")
  player2Wins    Int        @default(0) @map("player2_wins")
  draws          Int        @default(0)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tournament   Tournament   @relation(fields: [tournamentId], references: [id])
  player1     User         @relation("Player1", fields: [player1Id], references: [id])
  player2     User?        @relation("Player2", fields: [player2Id], references: [id])
  participants Participant[] @relation("ParticipantMatches")

  @@unique([tournamentId, roundNumber, tableNumber])
  @@map("matches")
}